# 🛡️ Delta Force Community Bot - Environment Configuration
# MANDATORY: Fill all values below to ensure bot functionality.

# [CORE] Bot Token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# [DATABASE] Filename for the local JSON database
# Example: localdb.json
LOCAL_DB_PATH=localdb.json

# [ADMIN] Your Telegram User ID (Numeric)
OWNER_ID=0

# [ADMIN] List of Admin User IDs separated by comma
ADMIN_IDS=123,456

# [LOGGING] Telegram Group ID for audit logs (Include minus sign for groups)
LOG_GROUP_ID=0

# [UI] Auto-delete delay for group messages in seconds
AUTO_DELETE_DELAY=60

# [DATA] Path to weapons/loadout data
LOADOUT_PATH=data/loadout.json
